# Server
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=ticketdb

# JWT — REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32-output
JWT_EXPIRY_HOURS=24

# Environment: development | production
# In production, SQL query logging is disabled.
APP_ENV=development
